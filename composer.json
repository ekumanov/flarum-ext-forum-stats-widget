{
    "name": "ekumanov/flarum-ext-forum-widgets",
    "description": "Forum Stats Widget — online users, discussion/post/user counts, and latest registration in a compact sidebar widget for Flarum 2.0",
    "keywords": [
        "flarum",
        "extension",
        "widget",
        "statistics",
        "online-users",
        "sidebar"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "require": {
        "flarum/core": "^2.0",
        "php": "^8.2"
    },
    "authors": [
        {
            "name": "ekumanov",
            "email": "ekumanov@users.noreply.github.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Ekumanov\\ForumWidgets\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Forum Stats Widget",
            "icon": {
                "name": "fas fa-chart-bar",
                "backgroundColor": "#4A90D9",
                "color": "#fff"
            }
        }
    }
}
